{
  "name": "@low-cost-avatar/react",
  "version": "0.1.0",
  "description": "React component for low-cost-avatar SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "low-cost-avatar": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
